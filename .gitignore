# ============================================================
# WAVEFORM — .gitignore
# ============================================================

# ── Secrets — NE JAMAIS COMMITTER ────────────────────────────
.env
.env.local
.env.*.local
frontend/.env.local
frontend/.env.*.local
apps/web/.env.local
apps/web/.env.*.local
apps/mobile/.env.local
apps/mobile/.env.*.local
/supabase
supabase_rls*

# ── Node ─────────────────────────────────────────────────────
node_modules/

# ── Next.js ──────────────────────────────────────────────────
apps/web/.next/
apps/web/out/
apps/web/.vercel
apps/web/next-env.d.ts

# ── Script audit reports (generated, not source) ──────────────
apps/web/scripts/*-report.json

# ── Build ────────────────────────────────────────────────────
dist/
build/
*.tsbuildinfo

# ── IDE ──────────────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.suo
*.sw?

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ── Misc ─────────────────────────────────────────────────────
*.bak
*.orig
*.seed
tmp*
nul
.cache/
.eslintcache
/coverage/


.claude

.agents