# ── Secrets — NE JAMAIS COMMITTER ────────────────────────────
.env
.env.local
.env.*.local
frontend/.env.local
frontend/.env.*.local
supabase
supabase_rls*

# ── Node ─────────────────────────────────────────────────────
node_modules/
frontend/node_modules/

# ── Next.js ──────────────────────────────────────────────────
frontend/.next/
frontend/out/
frontend/.vercel
frontend/next-env.d.ts

# ── Build ────────────────────────────────────────────────────
dist/
build/
*.tsbuildinfo

# ── IDE ──────────────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.suo
*.sw?

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Misc ─────────────────────────────────────────────────────
*.bak
*.orig
*.seed
tmp*
nul
.cache/
.eslintcache
/coverage/

.claude
