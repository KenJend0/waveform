# Example environment variables for local development
# Copy this file to .env.local and fill in real values. Do NOT commit secrets.

# Supabase (public values used by the frontend)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service key (server-side only)
SUPABASE_SERVICE_KEY=

# Base URL for frontend (used in links / redirects)
# Example: http://localhost:3000
NEXT_PUBLIC_FRONTEND_BASE=http://localhost:3000

# Upstash Redis (optional, enables server-side rate limiting)
# If omitted, rate limiting stays fail-open and requests are not blocked.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Last.fm API (metadata enrichment — genres, descriptions)
# Créer une clé : https://www.last.fm/api/account/create
LASTFM_API_KEY=
SPOTIFY_CLIENT_ID =
SPOTIFY_CLIENT_SECRET=

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

HUGGINGFACE_API_TOKEN=

NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
NEXT_PUBLIC_VERCEL_ENV=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

VERCEL_ENV=

NEXT_PUBLIC_FRONTEND_BASE =